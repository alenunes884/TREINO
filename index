<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FOCUSPRO - Protocolo Endomorfo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #05070a;
            color: white;
            -webkit-tap-highlight-color: transparent;
        }

        .glass {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
    </style>
</head>
<body class="pb-28">
    <!-- Brilhos de Fundo -->
    <div class="fixed top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-lime-500/10 blur-[120px] rounded-full"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-blue-500/10 blur-[120px] rounded-full"></div>
    </div>

    <!-- Cabeçalho -->
    <header class="relative z-10 p-6 flex justify-between items-center bg-black/40 backdrop-blur-md border-b border-white/5 sticky top-0">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-lime-500 rounded-xl flex items-center justify-center shadow-[0_0_20px_rgba(132,204,22,0.4)]">
                <i data-lucide="zap" class="text-black w-6 h-6"></i>
            </div>
            <div>
                <h1 class="text-xl font-black tracking-tighter italic leading-none text-white">FOCUS<span class="text-lime-500">PRO</span></h1>
                <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mt-1">Protocolo Endomorfo</p>
            </div>
        </div>
        <div class="bg-white/5 p-2 rounded-lg border border-white/10">
            <i data-lucide="user" class="w-5 h-5 text-slate-400"></i>
        </div>
    </header>

    <main class="relative z-10 p-5 max-w-md mx-auto space-y-8">
        
        <!-- ABA DASHBOARD -->
        <div id="dashboard" class="tab-content active space-y-6">
            <section class="bg-gradient-to-br from-slate-900 to-slate-950 p-6 rounded-[32px] border border-white/10 shadow-2xl relative overflow-hidden group">
                <p class="text-[10px] font-black text-lime-500 uppercase tracking-[0.2em] mb-4">Composição Corporal</p>
                <div class="grid grid-cols-2 gap-8">
                    <div>
                        <p class="text-3xl font-black">120.5<span class="text-sm font-medium text-slate-500 ml-1">kg</span></p>
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-tighter">Peso Atual</p>
                    </div>
                    <div class="text-right">
                        <p class="text-3xl font-black text-red-500">23</p>
                        <p class="text-xs text-slate-400 font-bold uppercase tracking-tighter italic underline decoration-red-500/50">Gordura Visceral</p>
                    </div>
                </div>
                <div class="mt-8 pt-6 border-t border-white/5 flex justify-between items-center">
                    <div class="flex items-center gap-2 text-[10px] font-bold text-slate-300 uppercase">
                        <div class="w-2 h-2 rounded-full bg-lime-500 shadow-[0_0_8px_rgba(132,204,22,1)]"></div>
                        Músculo: 25,4%
                    </div>
                    <div class="flex items-center gap-2 text-[10px] font-bold text-slate-300 uppercase">
                        <i data-lucide="trending-down" class="w-4 h-4 text-lime-500"></i>
                        Meta: -1kg/sem
                    </div>
                </div>
            </section>

            <section class="grid grid-cols-3 gap-3 text-center">
                <div class="bg-white/5 border border-white/5 p-3 rounded-2xl">
                    <div class="w-1 h-4 rounded-full mx-auto mb-2 bg-blue-500"></div>
                    <p class="text-sm font-black">190g</p>
                    <p class="text-[9px] font-bold text-slate-500 uppercase">Prot</p>
                </div>
                <div class="bg-white/5 border border-white/5 p-3 rounded-2xl">
                    <div class="w-1 h-4 rounded-full mx-auto mb-2 bg-lime-500"></div>
                    <p class="text-sm font-black">250g</p>
                    <p class="text-[9px] font-bold text-slate-500 uppercase">Carbo</p>
                </div>
                <div class="bg-white/5 border border-white/5 p-3 rounded-2xl">
                    <div class="w-1 h-4 rounded-full mx-auto mb-2 bg-orange-500"></div>
                    <p class="text-sm font-black">65g</p>
                    <p class="text-[9px] font-bold text-slate-500 uppercase">Gord</p>
                </div>
            </section>

            <section class="space-y-3">
                <h3 class="text-xs font-black uppercase tracking-widest text-slate-500 flex items-center gap-2 px-1">
                    <i data-lucide="award" class="w-4 h-4"></i> Hábitos de Performance
                </h3>
                <div onclick="toggleTask(this)" class="group flex items-center justify-between p-4 rounded-2xl border bg-white/5 border-white/5 cursor-pointer transition-all">
                    <span class="text-sm font-bold tracking-tight text-slate-200">Treino de Força</span>
                    <div class="checkbox w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center transition-all"></div>
                </div>
                <div onclick="toggleTask(this)" class="group flex items-center justify-between p-4 rounded-2xl border bg-white/5 border-white/5 cursor-pointer transition-all">
                    <span class="text-sm font-bold tracking-tight text-slate-200">Alta Ingestão Proteica</span>
                    <div class="checkbox w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center transition-all"></div>
                </div>
                <div onclick="toggleTask(this)" class="group flex items-center justify-between p-4 rounded-2xl border bg-white/5 border-white/5 cursor-pointer transition-all">
                    <span class="text-sm font-bold tracking-tight text-slate-200">Zero Ultraprocessados</span>
                    <div class="checkbox w-6 h-6 rounded-lg bg-white/10 flex items-center justify-center transition-all"></div>
                </div>
            </section>

            <section class="bg-blue-600/10 border border-blue-500/20 p-6 rounded-[32px] relative overflow-hidden">
                <div class="flex justify-between items-end mb-4 relative z-10">
                    <div>
                        <p class="text-[10px] font-black text-blue-400 uppercase tracking-widest mb-1 italic underline decoration-blue-500/30">Hidratação</p>
                        <h4 class="text-3xl font-black text-white"><span id="water-val">0.0</span> <span class="text-lg font-medium opacity-40">/ 4.5L</span></h4>
                    </div>
                    <button onclick="addWater()" class="bg-blue-600 p-4 rounded-2xl shadow-xl shadow-blue-600/30 active:scale-90 transition-all">
                        <i data-lucide="droplets" class="w-6 h-6 text-white"></i>
                    </button>
                </div>
                <div class="h-2 bg-blue-900/40 rounded-full overflow-hidden relative z-10">
                    <div id="water-bar" class="h-full bg-gradient-to-r from-blue-600 to-blue-400 transition-all duration-1000 shadow-[0_0_15px_rgba(59,130,246,0.5)]" style="width: 0%"></div>
                </div>
            </section>
        </div>

        <!-- ABA DIETA -->
        <div id="diet" class="tab-content space-y-6">
            <div class="bg-white/5 border border-white/10 p-5 rounded-[24px] flex items-center gap-4">
                <div class="w-12 h-12 bg-amber-500/20 rounded-xl flex items-center justify-center text-amber-500">
                    <i data-lucide="shopping-cart"></i>
                </div>
                <div>
                    <h4 class="text-xs font-black uppercase tracking-tighter text-amber-500">Estratégia Económica</h4>
                    <p class="text-[11px] text-slate-400 italic">"Proteína de ovos/soja + Carbos em massa. Desperdício zero."</p>
                </div>
            </div>

            <div class="space-y-4">
                <div class="bg-slate-900/60 backdrop-blur-sm border border-white/5 p-5 rounded-[24px] flex gap-5">
                    <div class="text-3xl bg-white/5 w-14 h-14 rounded-2xl flex items-center justify-center">🍳</div>
                    <div class="flex-1">
                        <div class="flex justify-between items-center mb-1">
                            <h4 class="text-[11px] font-black uppercase tracking-widest text-lime-500 italic">Café da Manhã</h4>
                            <span class="text-[9px] font-bold text-slate-600 flex items-center gap-1"><i data-lucide="clock" class="w-3 h-3"></i> 07:30</span>
                        </div>
                        <p class="text-sm font-bold text-slate-100">3 Ovos + 2 Fatias de Pão Integral</p>
                        <div class="mt-2 text-[9px] font-black text-slate-600 bg-white/5 px-2 py-0.5 rounded-full w-fit">420 KCAL</div>
                    </div>
                </div>
                <div class="bg-slate-900/60 backdrop-blur-sm border border-white/5 p-5 rounded-[24px] flex gap-5">
                    <div class="text-3xl bg-white/5 w-14 h-14 rounded-2xl flex items-center justify-center">🍱</div>
                    <div class="flex-1">
                        <div class="flex justify-between items-center mb-1">
                            <h4 class="text-[11px] font-black uppercase tracking-widest text-lime-500 italic">Almoço</h4>
                            <span class="text-[9px] font-bold text-slate-600 flex items-center gap-1"><i data-lucide="clock" class="w-3 h-3"></i> 12:00</span>
                        </div>
                        <p class="text-sm font-bold text-slate-100">150g Frango + Arroz + Feijão + Repolho</p>
                        <div class="mt-2 text-[9px] font-black text-slate-600 bg-white/5 px-2 py-0.5 rounded-full w-fit">710 KCAL</div>
                    </div>
                </div>
                <div class="bg-slate-900/60 backdrop-blur-sm border border-white/5 p-5 rounded-[24px] flex gap-5">
                    <div class="text-3xl bg-white/5 w-14 h-14 rounded-2xl flex items-center justify-center">🥜</div>
                    <div class="flex-1">
                        <div class="flex justify-between items-center mb-1">
                            <h4 class="text-[11px] font-black uppercase tracking-widest text-lime-500 italic">Lanche</h4>
                            <span class="text-[9px] font-bold text-slate-600 flex items-center gap-1"><i data-lucide="clock" class="w-3 h-3"></i> 16:30</span>
                        </div>
                        <p class="text-sm font-bold text-slate-100">1 Banana + Amendoim Torrado</p>
                        <div class="mt-2 text-[9px] font-black text-slate-600 bg-white/5 px-2 py-0.5 rounded-full w-fit">340 KCAL</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ABA TREINO -->
        <div id="training" class="tab-content space-y-6">
            <div class="flex bg-white/5 p-1.5 rounded-[24px] border border-white/5 gap-1 shadow-inner">
                <button onclick="setWorkout('A', this)" class="workout-btn flex-1 py-4 rounded-[18px] text-xs font-black transition-all bg-gradient-to-r from-blue-500 to-cyan-500 text-white shadow-xl">TREINO A</button>
                <button onclick="setWorkout('B', this)" class="workout-btn flex-1 py-4 rounded-[18px] text-xs font-black transition-all text-slate-500">TREINO B</button>
                <button onclick="setWorkout('C', this)" class="workout-btn flex-1 py-4 rounded-[18px] text-xs font-black transition-all text-slate-500">TREINO C</button>
            </div>

            <div class="bg-slate-900/50 border border-white/5 rounded-[32px] overflow-hidden shadow-2xl relative">
                <div id="workout-header" class="p-6 bg-gradient-to-r from-blue-500 to-cyan-500">
                    <h3 id="workout-title" class="text-2xl font-black italic tracking-tighter leading-tight">Peito e Braços</h3>
                    <p id="workout-sub" class="text-[10px] font-black uppercase tracking-[0.2em] opacity-80">Força e Volume</p>
                </div>
                <div id="exercise-list" class="p-2 divide-y divide-white/5">
                    <!-- Exercícios inseridos via JS -->
                </div>
            </div>

            <div class="bg-gradient-to-br from-red-600/20 to-orange-600/10 border border-red-500/20 p-6 rounded-[32px] flex items-center gap-6">
                <div class="w-16 h-16 bg-red-600 rounded-2xl flex items-center justify-center shadow-2xl shadow-red-600/30">
                    <i data-lucide="flame" class="w-8 h-8 text-white"></i>
                </div>
                <div class="flex-1">
                    <h4 class="text-xs font-black text-red-500 uppercase italic tracking-widest mb-1">Finalização Metabólica</h4>
                    <p class="text-xs text-slate-400 font-medium leading-snug">
                        <span class="text-white font-bold tracking-tight">20-30 min de Caminhada Acelerada.</span> Essencial para oxidar a gordura.
                    </p>
                </div>
            </div>
        </div>

    </main>

    <!-- Navegação Inferior -->
    <nav class="fixed bottom-0 left-0 right-0 p-4 z-50">
        <div class="max-w-md mx-auto bg-slate-900/80 backdrop-blur-2xl border border-white/10 rounded-[30px] p-2 flex justify-around items-center shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
            <button onclick="showTab('dashboard', this)" class="nav-btn flex flex-col items-center py-2 px-6 rounded-2xl transition-all text-lime-500 scale-110">
                <i data-lucide="layout-dashboard" class="w-6 h-6 mb-1"></i>
                <span class="text-[9px] font-black uppercase tracking-tighter">Status</span>
                <div class="active-dot absolute -bottom-1 w-1 h-1 bg-lime-500 rounded-full shadow-[0_0_10px_rgba(132,204,22,1)]"></div>
            </button>
            <button onclick="showTab('diet', this)" class="nav-btn flex flex-col items-center py-2 px-6 rounded-2xl transition-all text-slate-500">
                <i data-lucide="utensils" class="w-6 h-6 mb-1"></i>
                <span class="text-[9px] font-black uppercase tracking-tighter">Dieta</span>
            </button>
            <button onclick="showTab('training', this)" class="nav-btn flex flex-col items-center py-2 px-6 rounded-2xl transition-all text-slate-500">
                <i data-lucide="dumbbell" class="w-6 h-6 mb-1"></i>
                <span class="text-[9px] font-black uppercase tracking-tighter">Treino</span>
            </button>
        </div>
    </nav>

    <script>
        // Inicialização de Ícones
        lucide.createIcons();

        // Estado Global
        let water = 0;
        const waterGoal = 4.5;

        const workoutData = {
            A: {
                title: "Peito e Braços",
                subtitle: "Força e Volume",
                color: "from-blue-500 to-cyan-500",
                exercises: [
                    { name: 'Supino Reto', sets: '3 x 12', detail: 'Halteres' },
                    { name: 'Crucifixo Reto', sets: '3 x 15', detail: 'Peito' },
                    { name: 'Rosca Direta', sets: '4 x 12', detail: 'Bíceps' },
                    { name: 'Rosca Alternada', sets: '3 x 12', detail: 'Braço' },
                    { name: 'Tríceps Pulley', sets: '4 x 12', detail: 'Corda' },
                    { name: 'Tríceps Testa', sets: '3 x 12', detail: 'Halter' }
                ]
            },
            B: {
                title: "Costas e Ombros",
                subtitle: "Largura e Postura",
                color: "from-purple-500 to-indigo-500",
                exercises: [
                    { name: 'Puxada Frente', sets: '3 x 12', detail: 'Dorsal' },
                    { name: 'Remada Baixa', sets: '3 x 15', detail: 'Triângulo' },
                    { name: 'Remada Serrote', sets: '3 x 12', detail: 'Halter' },
                    { name: 'Desenvolvimento', sets: '3 x 12', detail: 'Ombro' },
                    { name: 'Elevação Lateral', sets: '4 x 15', detail: 'Lateral' },
                    { name: 'Encolhimento', sets: '3 x 15', detail: 'Trapézio' }
                ]
            },
            C: {
                title: "Pernas e Glúteos",
                subtitle: "Base e Potência",
                color: "from-orange-500 to-red-500",
                exercises: [
                    { name: 'Leg Press 45°', sets: '3 x 15', detail: 'Quadríceps' },
                    { name: 'Cadeira Extensora', sets: '3 x 15', detail: 'Foco Frontal' },
                    { name: 'Cadeira Flexora', sets: '3 x 15', detail: 'Posterior' },
                    { name: 'Agachamento Sumô', sets: '4 x 12', detail: 'Glúteo' },
                    { name: 'Elevação Pélvica', sets: '3 x 15', detail: 'Glúteo' },
                    { name: 'Panturrilha em Pé', sets: '4 x 20', detail: 'Perna' }
                ]
            }
        };

        // Funções de Navegação
        function showTab(tabId, btn) {
            // Esconder todos
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');

            // Atualizar botões
            document.querySelectorAll('.nav-btn').forEach(el => {
                el.classList.remove('text-lime-500', 'scale-110');
                el.classList.add('text-slate-500');
                const dot = el.querySelector('.active-dot');
                if (dot) dot.remove();
            });

            btn.classList.add('text-lime-500', 'scale-110');
            btn.classList.remove('text-slate-500');
            btn.insertAdjacentHTML('beforeend', '<div class="active-dot absolute -bottom-1 w-1 h-1 bg-lime-500 rounded-full shadow-[0_0_10px_rgba(132,204,22,1)]"></div>');
        }

        // Funções de Água
        function addWater() {
            if (water < waterGoal) {
                water += 0.5;
                document.getElementById('water-val').innerText = water.toFixed(1);
                const percent = (water / waterGoal) * 100;
                document.getElementById('water-bar').style.width = Math.min(percent, 100) + '%';
            }
        }

        // Funções de Hábitos
        function toggleTask(el) {
            const checkbox = el.querySelector('.checkbox');
            const span = el.querySelector('span');
            
            if (el.classList.contains('completed')) {
                el.classList.remove('completed', 'bg-lime-500/10', 'border-lime-500/40', 'translate-x-1');
                checkbox.innerHTML = '';
                checkbox.classList.add('bg-white/10');
                checkbox.classList.remove('bg-lime-500');
                span.classList.remove('text-lime-400', 'line-through', 'opacity-60');
                span.classList.add('text-slate-200');
            } else {
                el.classList.add('completed', 'bg-lime-500/10', 'border-lime-500/40', 'translate-x-1');
                checkbox.innerHTML = '<i data-lucide="check" class="w-4 h-4 text-black"></i>';
                checkbox.classList.remove('bg-white/10');
                checkbox.classList.add('bg-lime-500');
                span.classList.add('text-lime-400', 'line-through', 'opacity-60');
                span.classList.remove('text-slate-200');
                lucide.createIcons();
            }
        }

        // Funções de Treino
        function setWorkout(day, btn) {
            const data = workoutData[day];
            
            // Botões
            document.querySelectorAll('.workout-btn').forEach(b => {
                b.className = "workout-btn flex-1 py-4 rounded-[18px] text-xs font-black transition-all text-slate-500";
            });
            btn.className = `workout-btn flex-1 py-4 rounded-[18px] text-xs font-black transition-all bg-gradient-to-r ${data.color} text-white shadow-xl`;

            // Conteúdo
            const header = document.getElementById('workout-header');
            header.className = `p-6 bg-gradient-to-r ${data.color}`;
            document.getElementById('workout-title').innerText = data.title;
            document.getElementById('workout-sub').innerText = data.subtitle;

            const list = document.getElementById('exercise-list');
            list.innerHTML = data.exercises.map(ex => `
                <div class="p-4 flex justify-between items-center hover:bg-white/5 transition-all group">
                    <div>
                        <h4 class="text-sm font-bold text-slate-200 group-hover:text-white">${ex.name}</h4>
                        <div class="flex items-center gap-2 mt-1">
                            <div class="w-1.5 h-1.5 rounded-full bg-white/20"></div>
                            <span class="text-[10px] font-bold text-slate-500 uppercase tracking-tighter">${ex.detail}</span>
                        </div>
                    </div>
                    <div class="bg-black/40 px-4 py-2 rounded-xl border border-white/5">
                        <span class="text-xs font-black text-white italic">${ex.sets}</span>
                    </div>
                </div>
            `).join('');
        }

        // Carregar Treino A inicialmente
        setWorkout('A', document.querySelector('.workout-btn'));
    </script>
</body>
</html>
